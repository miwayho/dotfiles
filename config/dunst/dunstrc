[global]
width = 350
height = 100
frame_color = "#282726"
separator_color= frame
origin = top-right
offset = 25x25
font = Fira Code 12
frame_width = 3

[urgency_low]
background = "#1C1B1A"
foreground = "#FFFCF0"
timeout = 10

[urgency_normal]
background = "#1C1B1A"
foreground = "#FFFCF0"
timeout = 15

[urgency_critical]
background = "#1C1B1A"
foreground = "#FFFCF0"
frame_color = "#AF3029"
timeout = 30
